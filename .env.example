APP_ENV=prod

BCB_TARGET_SERIES_CODE=21085
BCB_NORTH_PROXY_SERIES_CODE=24363

# SIDRA monthly indicator (IPCA full index, Brazil level).
# Note: this keeps the ingestion path fully real and stable for the default local demo.
SIDRA_AM_URL=https://apisidra.ibge.gov.br/values/t/7060/n1/all/v/63/p/all?formato=json

# Preferred: normalized CSV with columns: year_month, am_net_jobs
# Keep this populated for the default local demo path.
CAGED_AM_CSV_URL=https://raw.githubusercontent.com/adrianogaraujo/Seu-modelo-de-ML/Main/datasets/caged_am_monthly.csv

# Optional official monthly XLSX source (example from Jul/2025 folder extraction):
# https://drive.google.com/uc?export=download&id=1ur1_lVFTHOqE0ANEKch0L7cP2ylCJO6J
CAGED_AM_XLSX_URL=

# Optional API base URL override used by Streamlit dashboard.
# Local run example: http://localhost:8000
API_BASE_URL=http://api:8000
